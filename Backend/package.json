{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",

    "prisma:generate": "dotenv -e .env -- prisma generate",
    "migrate:dev": "dotenv -e .env -- prisma migrate dev",
    "migrate:test": "dotenv -e .env.test -- prisma migrate dev",
    "migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "studio": "dotenv -e .env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "prisma": "6.19.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.1.0",
    "dotenv-cli": "^7.4.4",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
